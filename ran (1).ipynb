      "source": [
        "# برنامج جمع الأعداد الزوجية\n",
        "\n",
        "num = int(input(\"ادخل رقماً: \"))\n",
        "total = 0\n",
        "\n",
        "for i in range(1, num + 1):\n",
        "    if i % 2 == 0:   # التحقق أن العدد زوجي\n",
        "        total += i\n",
        "\n",
        "print(\"مجموع الأعداد الزوجية هو:\", total)"
      ],
